<div class="wt-footer wt-footer-contact hh-legal-notice hh-legal-notice-page my-2">
    <?= view($moduleName . '::page/header', get_defined_vars()) ?>

    <?php foreach ($chapters as $chapter) : ?>
        <?php if ($chapter->getLevel() !== 1 || !$chapter->getEnabled()) : ?>
            <?php continue; ?>
        <?php endif ?>

        <?php if ($chapter->getKey() === 'DataProtection' && !$showDataProtection) : ?>
            <?php continue; ?>
        <?php endif ?>

        <?php if ($chapter->getKey() === 'LegalRegulations' && !$showLegalRegulations) : ?>
            <?php continue; ?>
        <?php endif ?>

        <?= view($moduleName . '::page/chapter', array_merge(get_defined_vars(), ['mainChapter' => $chapter])) ?>
    <?php endforeach ?>
</div>

