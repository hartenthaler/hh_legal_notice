    <script>
        $('.wt-table-menu td.move').click(function () {
            var row = $(this).closest('tr');

            if ($(this).hasClass('up')) {
                row.prev().before(row);
            } else {
                row.next().after(row);
            }

            return false;
        });

        function hhLegalNoticeParentIsVisible(chapterKey) {
            var checkbox = $('[data-controls-chapters="' + chapterKey + '"]');
            var parentGroup = checkbox.closest('.hh-legal-notice-dependent-chapters');

            return checkbox.prop('checked') && (parentGroup.length === 0 || !parentGroup.hasClass('d-none'));
        }

        function hhLegalNoticeUpdateDependentChapters() {
            $('.hh-legal-notice-dependent-chapters').each(function () {
                $(this).toggleClass('d-none', !hhLegalNoticeParentIsVisible($(this).data('parent-key')));
            });

            $('.hh-legal-notice-section-setting').each(function () {
                $(this).toggleClass('d-none', !hhLegalNoticeParentIsVisible($(this).data('dependent-on-chapter')));
            });
        }

        $('[data-controls-chapters]').on('change', hhLegalNoticeUpdateDependentChapters);
        hhLegalNoticeUpdateDependentChapters();
    </script>
<?php View::endpush() ?>

