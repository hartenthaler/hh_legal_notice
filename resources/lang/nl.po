msgstr "Naam/namen, bijv. \"De Jong\""

#: LegalNoticeFooterModule.php:901
msgid "Place(s) or region, e.g. \"Bautzen, Löbau\""
msgstr "Plaats(en) of regio, bijv. \"Amsterdam, Rotterdam\""

#: LegalNoticeFooterModule.php:902
msgid "Region or farm type, e.g. \"Black Forest farms, Wolfach district\""
msgstr "Regio of type boerderij, bijv. \"Zeeuwse boerderijen, Walcheren\""

#: LegalNoticeFooterModule.php:903
msgid "Topic, e.g. \"Students of the Bautzen grammar school 1600-1900\""
