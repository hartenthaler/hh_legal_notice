msgid_plural "%1$s: inactive since %2$s (%3$s years)."
msgstr[0] "%1$s: inactief sinds %2$s (%3$s jaar)."
msgstr[1] "%1$s: inactief sinds %2$s (%3$s jaar)."

#: resources/views/settings.phtml:538
msgid "Privacy policy reference date"
msgstr "Referentiedatum van de privacyverklaring"

#: resources/views/settings.phtml:542
msgid "Which date should be shown in the privacy policy?"
msgstr "Welke datum moet in de privacyverklaring worden weergegeven?"

#: resources/views/settings.phtml:549
msgid "Module release date"
msgstr "Releasedatum van de module"

#: resources/views/settings.phtml:550
msgid "Manually configured date"
msgstr "Handmatig ingestelde datum"

#: resources/views/settings.phtml:551
msgid "Current date"
msgstr "Huidige datum"

#: resources/views/settings.phtml:556
msgid ""
"Use the current date only if you want the dynamically generated privacy "
"policy to always show the day on which it is viewed."
msgstr ""
"Gebruik de huidige datum alleen wanneer de dynamisch gegenereerde "
"privacyverklaring steeds de dag moet tonen waarop zij wordt geraadpleegd."

#: resources/views/settings.phtml:561
msgid "Manual privacy policy date"
msgstr "Handmatig ingestelde datum van de privacyverklaring"

#: resources/views/settings.phtml:566
msgid "Used only when the manually configured date option is selected."
msgstr ""
"Wordt alleen gebruikt wanneer de optie voor een handmatig ingestelde datum "
"is geselecteerd."

#: resources/views/settings.phtml:572
msgid "Server location"
msgstr "Serverlocatie"

#: resources/views/settings.phtml:577
msgid "Country of the webtrees server location"
msgstr "Land waar de webtrees-server zich bevindt"

#: resources/views/settings.phtml:585
msgid "Hosting service"
msgstr "Hostingprovider"

#: resources/views/settings.phtml:590
msgid "Name of hosting service company"
msgstr "Naam van de hostingprovider"

#: resources/views/settings.phtml:598
msgid "Hosting service link (URL)"
msgstr "Link naar de hostingprovider (URL)"

#: resources/views/settings.phtml:606
msgid "Hosting service link to privacy notice (URL)"
msgstr "Link naar de privacyverklaring van de hostingprovider (URL)"

#: resources/views/settings.phtml:615
msgid "Should a section about Order Processing agreement be shown?"
msgstr "Moet een sectie over de verwerkersovereenkomst worden weergegeven?"

#: resources/views/settings.phtml:628
msgid "First date of Order Processing agreement"
msgstr "Datum van de eerste verwerkersovereenkomst"

#: resources/views/settings.phtml:636
msgid "Last date of Order Processing agreement"
msgstr "Datum van de meest recente verwerkersovereenkomst"

#: resources/views/settings.phtml:649
msgid "Protection period after death"
msgstr "Beschermingsperiode na overlijden"

#: resources/views/settings.phtml:655
msgid ""
"For how many years after death should particularly sensitive genealogical "
"data remain protected?"
msgstr ""
"Hoeveel jaar na het overlijden moeten bijzonder gevoelige genealogische "
"gegevens beschermd blijven?"

#: resources/views/settings.phtml:656
msgid ""
"Use 0 if no specific release period should be stated in the privacy policy."
msgstr ""
"Gebruik 0 als er in de privacyverklaring geen specifieke vrijgaveperiode "
"moet worden vermeld."

#: resources/views/settings.phtml:657
msgid ""
"The same period should be used by the privacy assistant when applying RESN "
"CONFIDENTIAL automatically."
msgstr ""
"Dezelfde periode moet door de privacyassistent worden gebruikt wanneer RESN "
"CONFIDENTIAL automatisch wordt toegepast."

#: resources/views/settings.phtml:664
msgid "Supervisory authority"
msgstr "Toezichthoudende autoriteit"

#: resources/views/settings.phtml:668
msgid "Name of the competent supervisory authority"
msgstr "Naam van de bevoegde toezichthoudende autoriteit"

#: resources/views/settings.phtml:673
msgid ""
"If this field is empty, no specific supervisory authority is named in the "
"privacy policy."
msgstr ""
"Als dit veld leeg is, wordt in de privacyverklaring geen specifieke "
"toezichthoudende autoriteit genoemd."

#: resources/views/settings.phtml:678
msgid "URL of the competent supervisory authority"
msgstr "URL van de bevoegde toezichthoudende autoriteit"

#: resources/views/settings.phtml:683
msgid ""
"The specific supervisory authority is linked only when both name and URL are "
"configured."
msgstr ""
"De specifieke toezichthoudende autoriteit wordt alleen gekoppeld wanneer "
"zowel naam als URL zijn ingesteld."

#: resources/views/settings.phtml:690
msgid "External services"
msgstr "Externe diensten"

#: resources/views/settings.phtml:696
msgid "Should Google Charts be mentioned as an external service?"
msgstr "Moet Google Charts als externe dienst worden vermeld?"

#: resources/views/settings.phtml:706
#, php-format
msgid "webtrees statistics pages can load Google Charts from %s."
msgstr "webtrees-statistiekpagina's kunnen Google Charts laden vanaf %s."

#: resources/views/settings.phtml:707
msgid ""
"Google Charts is only listed when this option is enabled and the webtrees "
"statistics chart module is enabled."
msgstr ""
"Google Charts wordt alleen vermeld wanneer deze optie is ingeschakeld en de "
"webtrees-module voor statistiekgrafieken is ingeschakeld."

#: resources/views/settings.phtml:714
msgid "Additional third-party services"
msgstr "Aanvullende diensten van derden"

#: resources/views/settings.phtml:719
#, php-format
msgid ""
"Enter one service per line using the format “Name | URL | Country”. The "
"country is optional, but should be provided when known. Example: %s"
msgstr ""
"Voer één dienst per regel in volgens het formaat “Naam | URL | Land”. Het "
"land is optioneel, maar moet worden opgegeven als het bekend is. Voorbeeld: "
"%s"

